command = ~/bin/tmux-start.sh

link-url = true
maximize = true
auto-update = "check"
mouse-hide-while-typing = true

# Theme
# -----
theme = covid19
font-size = 14
font-family = "Monaco"
font-feature = -calt, -liga, -dlig

# MacOS specific settings
# -----------------------
macos-icon = "retro"
macos-option-as-alt = true
macos-titlebar-style = "hidden"
window-save-state = "always"
quit-after-last-window-closed = true

# Disable some default keybindings (because of tmux)
# -------------------------------------------------
# I don't use Ghostty tabs
keybind = super+shift+bracket_left=unbind
keybind = super+shift+bracket_right=unbind
keybind = super+alt+w=unbind
keybind = ctrl+shift+tab=unbind
keybind = super+[=unbind
keybind = super+]=unbind

# # I don't use Ghostty splits
keybind = super+ctrl+equal=unbind
keybind = super+bracket_left=unbind
keybind = super+bracket_right=unbind
keybind = super+alt+arrow_left=unbind
keybind = super+alt+arrow_right=unbind
keybind = super+alt+arrow_up=unbind
keybind = super+alt+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+ctrl+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind

# Rebind default keybindings to tmux
# ----------------------------------

# new window
keybind = super+t=esc:t
# new session
keybind = super+n=esc:n
# select session
keybind = super+s=esc:s
# split horizontally
keybind = super+d=esc:d
# Split vertically
keybind = super+shift+d=esc:D
# Resize pane
keybind = super+z=esc:z
# Reload tmux config
keybind = super+r=esc:r
# Move windows
keybind = super+shift+left_bracket=text:\x1b{
keybind = super+shift+right_bracket=text:\x1b}
# Toggle windows
keybind = super+digit_1=esc:1
keybind = super+digit_2=esc:2
keybind = super+digit_3=esc:3
keybind = super+digit_4=esc:4
keybind = super+digit_5=esc:5
keybind = super+digit_6=esc:6
keybind = super+digit_7=esc:7
keybind = super+digit_8=esc:8
keybind = super+digit_9=esc:9
keybind = super+digit_0=esc:0
